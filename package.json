    "@shikijs/monaco": "4.0.2",
    "@tanstack/react-hotkeys": "0.10.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "client-zip": "2.5.0",
    "cmdk": "1.1.1",
    "dockview-core": "6.0.7",
    "dockview-react": "6.0.7",
    "jotai": "2.20.0",
    "lucide-react": "1.14.0",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-resizable-panels": "4.11.0",
