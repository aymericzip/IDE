    "@vitejs/plugin-react": "6.0.1",
    "bun": "1.3.13",
    "eslint": "10.3.0",
    "eslint-config-biome": "^2.1.3",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "material-icon-theme": "5.34.0",
    "tailwindcss": "4.3.0",
    "typescript": "~6.0.2",
